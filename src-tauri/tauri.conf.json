{
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build",
                  "devPath":  "http://localhost:1420",
                  "distDir":  "../dist"
              },
    "package":  {
                    "productName":  "MTCode",
                    "version":  "0.1.0"
                },
    "tauri":  {
                  "allowlist":  {
                                    "all":  false,
                                    "dialog":  {
                                                   "open":  true,
                                                   "save":  true
                                               },
                                    "fs":  {
                                               "readFile":  true,
                                               "writeFile":  true
                                           },
                                    "path":  {
                                                 "all":  true
                                             },
                                    "shell":  {
                                                  "open":  true
                                              },
                                    "window":  {
                                                   "all":  true
                                               }
                                },
                  "bundle":  {
                                 "active":  true,
                                 "targets":  [
                                                 "nsis"
                                             ],
                                 "identifier":  "com.mtcode.app",
                                 "windows":  {
                                                 "webviewInstallMode":  {
                                                                            "type":  "fixedRuntime",
                                                                            "path":  "./webview2-fixed-runtime/x64"
                                                                        }
                                             },
                                 "icon":  [
                                              "icons/32x32.png",
                                              "icons/128x128.png",
                                              "icons/128x128@2x.png",
                                              "icons/icon.icns",
                                              "icons/icon.ico"
                                          ]
                             },
                  "windows":  [
                                  {
                                      "title":  "MTCode",
                                      "width":  1280,
                                      "height":  820,
                                      "minWidth":  980,
                                      "minHeight":  640,
                                      "resizable":  true,
                                      "decorations":  false
                                  }
                              ]
              }
}